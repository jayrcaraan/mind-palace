# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=production          # production | development
ENABLE_DOCS=false               # expose /docs & /openapi.json (keep false in prod)

# ── Deployment Mode ──────────────────────────────────────────────────────────
# light    = parse + regex NER, no embeddings — runs on any laptop, no models
# standard = async embeddings, client-supplied entities
# advanced = + vision parsing + LLM entity extraction (bigger machine)
DEPLOYMENT_MODE=light

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=mindpalace
POSTGRES_USER=mindpalace
POSTGRES_PASSWORD=CHANGE_ME_use_a_long_random_secret
POSTGRES_PORT=5432

# ── Inference providers (OpenAI-compatible) ──────────────────────────────────
# Every provider speaks the OpenAI API, so each can be a local Ollama, OpenAI,
# or any compatible remote endpoint — configured independently.
#
# Shared default for all providers (override per-provider below to split them):
INFERENCE_BASE_URL=http://host.docker.internal:11434/v1
INFERENCE_API_KEY=not-needed
#
# Embedding provider (text → vector)        [standard, advanced]
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...
#
# LLM provider (entity extraction)          [advanced]
LLM_MODEL=gemma4:e4b
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
#
# OCR / vision provider (image → text)      [advanced]
OCR_MODEL=gemma4:e4b
# OCR_BASE_URL=https://api.openai.com/v1
# OCR_API_KEY=sk-...
#
# Example — remote OpenAI for everything:
#   INFERENCE_BASE_URL=https://api.openai.com/v1
#   INFERENCE_API_KEY=sk-...
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_DIMENSIONS=1536
#   LLM_MODEL=gpt-4o-mini
#   OCR_MODEL=gpt-4o-mini

# ── Inference timeouts (seconds) ─────────────────────────────────────────────
# Short connect → a bad/unreachable endpoint fails fast; generous read for slow
# generation. Raise OCR_TIMEOUT for big vision models on slow hardware.
# INFERENCE_CONNECT_TIMEOUT=5
# EMBEDDING_TIMEOUT=60
# OCR_TIMEOUT=180
# LLM_TIMEOUT=45
# PARSE_TIMEOUT=120      # max seconds to parse one document before failing it

# ── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Auth / identity ──────────────────────────────────────────────────────────
# Single-user deployments: requests without a bearer token are this admin UUID.
# Put the app behind a reverse-proxy auth gate (e.g. Authentik forward-auth) in prod.
ADMIN_USER_ID=00000000-0000-0000-0000-000000000001

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. The SPA is same-origin so it never needs CORS;
# only set this for cross-origin API/MCP clients.
CORS_ORIGINS=["https://mindpalace.example.com"]

# ── Production deploy (docker-compose.prod.yml only) ──────────────────────────
# The prod compose pulls pre-built images instead of building them.
# MP_IMAGE=registry.example.com/you/mind-palace:latest
# POSTGRES_IMAGE=mind-palace-db:pg16     # pgvector + Apache AGE (docker/postgres.Dockerfile)
